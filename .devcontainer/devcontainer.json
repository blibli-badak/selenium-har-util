{
  "name": "selenium-har-util",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "remoteEnv": {
    "CHROME_MODE": "headless"
  },
  "postCreateCommand": "mvn -q -DskipTests=true compile"
}
